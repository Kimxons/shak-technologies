---
const currentUrlPath = Astro.url.pathname.replace(/\/+$/, "");
const pathSegments = currentUrlPath.split("/").filter(Boolean);

const breadcrumbs = pathSegments.map((segment, index) => {
  let label = decodeURIComponent(segment).replace(/-/g, " ");

  if (index === 0) {
    label = segment.charAt(0).toUpperCase() + segment.slice(1);
  }

  if (segment === "index") {
    label = "Home";
  }

  if (
    (pathSegments[0] === "posts" || pathSegments[0] === "tags") &&
    index > 0 &&
    /^\d+$/.test(segment)
  ) {
    label = `Page ${segment}`;
  }

  return {
    label,
    href: `/${pathSegments.slice(0, index + 1).join("/")}`,
    isLast: index === pathSegments.length - 1,
  };
});
---

<nav class="breadcrumb" aria-label="breadcrumb">
  <ul>
    <li>
      <a href="/">Home</a>
      {breadcrumbs.length > 0 && <span aria-hidden="true">/</span>}
    </li>
    {
      breadcrumbs.map(crumb =>
        crumb.isLast ? (
          <li>
            <span aria-current="page">{crumb.label}</span>
          </li>
        ) : (
          <li>
            <a href={crumb.href}>{crumb.label}</a>
            <span aria-hidden="true">/</span>
          </li>
        )
      )
    }
  </ul>
</nav>

<style>
  .breadcrumb {
    @apply mx-auto mb-2 mt-8 w-full max-w-7xl px-4 sm:px-6;
  }
  .breadcrumb ul {
    @apply flex flex-wrap items-center gap-1 text-sm opacity-75;
  }
  .breadcrumb ul li {
    @apply inline-flex items-center gap-1;
  }
  .breadcrumb ul li a {
    @apply hover:text-skin-accent;
  }
  .breadcrumb ul li span {
    @apply opacity-80;
  }
</style>
