---
import { CONSULT_BOOKING_LINKS, LOGO_IMAGE, SITE } from "@config";
import LinkButton from "./LinkButton.astro";
import LogoSVG from "@assets/logo";

export interface Props {
  activeNav?:
    | "posts"
    | "tags"
    | "courses"
    | "consultancy"
    | "research"
    | "pricing"
    | "about"
    | "search";
}

const { activeNav } = Astro.props;

const courseLinks = [
  {
    name: "All Courses",
    href: "/courses",
    description: "See every available training track.",
    external: false,
  },
  {
    name: "Learning Format",
    href: "/courses#delivery",
    description: "Understand cohort flow and delivery model.",
    external: false,
  },
  {
    name: "Enroll Now",
    href: "/enroll",
    description: "Submit your enrollment form and secure your next cohort slot.",
    external: false,
  },
  {
    name: "Pricing Plans",
    href: "/pricing",
    description: "View online class pricing and consultancy options.",
    external: false,
  },
] as const;

const consultLinks = [
  {
    name: "Consultancy Overview",
    href: "/consultancy",
    description: "Review service scope and outcomes.",
    external: false,
  },
  {
    name: "Book 15-Min Discovery",
    href: CONSULT_BOOKING_LINKS.quick15,
    description: "Fast fit check and next-step guidance.",
    external: true,
  },
  {
    name: "Book 30-Min Strategy",
    href: CONSULT_BOOKING_LINKS.strategy30,
    description: "Deep dive into roadmap and implementation.",
    external: true,
  },
  {
    name: "Secret Meeting",
    href: CONSULT_BOOKING_LINKS.secret,
    description: "Private booking link for direct coordination.",
    external: true,
  },
] as const;
---

<header class="site-header">
  <a id="skip-to-content" href="#main-content" class="skip-link">Skip to content</a>
  <div class="nav-shell">
    <a href="/" class="logo" aria-label={`${SITE.title} home page`}>
      {
        LOGO_IMAGE.enable ? (
          LOGO_IMAGE.svg ? (
            <LogoSVG />
          ) : (
            <img
              src={`/assets/logo.png`}
              alt={SITE.title}
              width={LOGO_IMAGE.width}
              height={LOGO_IMAGE.height}
            />
          )
        ) : (
          <span>
            <span class="brand-title">{SITE.title}</span>
          </span>
        )
      }
    </a>

    <nav class="desktop-nav" aria-label="Main navigation">
      <ul class="desktop-nav-list">
        <li class="desktop-dropdown">
          <details>
            <summary class:list={["desktop-link", { active: activeNav === "courses" }]}>
              Courses
              <svg xmlns="http://www.w3.org/2000/svg" class="chevron">
                <path d="m7 10 5 5 5-5z"></path>
              </svg>
            </summary>
            <ul class="dropdown-menu">
              {courseLinks.map(link => (
                <li>
                  <a href={link.href} class="dropdown-link">
                    <span class="dropdown-name">{link.name}</span>
                    <span class="dropdown-desc">{link.description}</span>
                  </a>
                </li>
              ))}
            </ul>
          </details>
        </li>

        <li class="desktop-dropdown">
          <details>
            <summary class:list={["desktop-link", { active: activeNav === "consultancy" }]}>
              Consult
              <svg xmlns="http://www.w3.org/2000/svg" class="chevron">
                <path d="m7 10 5 5 5-5z"></path>
              </svg>
            </summary>
            <ul class="dropdown-menu">
              {consultLinks.map(link => (
                <li>
                  <a
                    href={link.href}
                    class="dropdown-link"
                    target={link.external ? "_blank" : undefined}
                    rel={link.external ? "noopener noreferrer" : undefined}
                  >
                    <span class="dropdown-name">{link.name}</span>
                    <span class="dropdown-desc">{link.description}</span>
                  </a>
                </li>
              ))}
            </ul>
          </details>
        </li>

        <li>
          <a href="/research" class:list={["desktop-link", { active: activeNav === "research" }]}>
            Research
          </a>
        </li>
        <li>
          <a href="/pricing" class:list={["desktop-link", { active: activeNav === "pricing" }]}>
            Pricing
          </a>
        </li>
        <li>
          <a href="/posts" class:list={["desktop-link", { active: activeNav === "posts" }]}>
            Insights
          </a>
        </li>
        <li>
          <a href="/about" class:list={["desktop-link", { active: activeNav === "about" }]}>
            About
          </a>
        </li>
      </ul>
    </nav>

    <div class="desktop-actions">
      <LinkButton
        href="/search"
        className={`icon-btn focus-outline ${activeNav === "search" ? "active" : ""}`}
        ariaLabel="Search website"
        title="Search"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="search-icon">
          <path d="M19.023 16.977a35.13 35.13 0 0 1-1.367-1.384c-.372-.378-.596-.653-.596-.653l-2.8-1.337A6.962 6.962 0 0 0 16 9c0-3.859-3.14-7-7-7S2 5.141 2 9s3.14 7 7 7c1.763 0 3.37-.66 4.603-1.739l1.337 2.8s.275.224.653.596c.387.363.896.854 1.384 1.367l1.358 1.392.604.646 2.121-2.121-.646-.604c-.379-.372-.885-.866-1.391-1.36zM9 14c-2.757 0-5-2.243-5-5s2.243-5 5-5 5 2.243 5 5-2.243 5-5 5z"></path>
        </svg>
        <span class="sr-only">Search</span>
      </LinkButton>

      {
        SITE.lightAndDarkMode && (
          <button
            id="theme-btn"
            class="focus-outline icon-btn"
            title="Toggles light and dark theme"
            aria-label="Current theme: auto"
            aria-live="polite"
          >
            <svg xmlns="http://www.w3.org/2000/svg" id="moon-svg" class="theme-icon">
              <path d="M20.742 13.045a8.088 8.088 0 0 1-2.077.271c-2.135 0-4.14-.83-5.646-2.336a8.025 8.025 0 0 1-2.064-7.723A1 1 0 0 0 9.73 2.034a10.014 10.014 0 0 0-4.489 2.582c-3.898 3.898-3.898 10.243 0 14.143a9.937 9.937 0 0 0 7.072 2.93 9.93 9.93 0 0 0 7.07-2.929 10.007 10.007 0 0 0 2.583-4.491 1.001 1.001 0 0 0-1.224-1.224zm-2.772 4.301a7.947 7.947 0 0 1-5.656 2.343 7.953 7.953 0 0 1-5.658-2.344c-3.118-3.119-3.118-8.195 0-11.314a7.923 7.923 0 0 1 2.06-1.483 10.027 10.027 0 0 0 2.89 7.848 9.972 9.972 0 0 0 7.848 2.891 8.036 8.036 0 0 1-1.484 2.059z" />
            </svg>
            <svg xmlns="http://www.w3.org/2000/svg" id="sun-svg" class="theme-icon">
              <path d="M6.993 12c0 2.761 2.246 5.007 5.007 5.007s5.007-2.246 5.007-5.007S14.761 6.993 12 6.993 6.993 9.239 6.993 12zM12 8.993c1.658 0 3.007 1.349 3.007 3.007S13.658 15.007 12 15.007 8.993 13.658 8.993 12 10.342 8.993 12 8.993zM10.998 19h2v3h-2zm0-17h2v3h-2zm-9 9h3v2h-3zm17 0h3v2h-3zM4.219 18.363l2.12-2.122 1.415 1.414-2.12 2.122zM16.24 6.344l2.122-2.122 1.414 1.414-2.122 2.122zM6.342 7.759 4.22 5.637l1.415-1.414 2.12 2.122zm13.434 10.605-1.414 1.414-2.122-2.122 1.414-1.414z"></path>
            </svg>
          </button>
        )
      }

      <LinkButton
        href={CONSULT_BOOKING_LINKS.quick15}
        className="cta-btn"
        title="Book a 15 minute discovery call"
        target="_blank"
        rel="noopener noreferrer"
      >
        Book 15-Min Call
      </LinkButton>
    </div>

    <button
      class="mobile-toggle focus-outline"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      aria-controls="mobile-panel"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="menu-icon"
      >
        <line x1="4" y1="7" x2="20" y2="7" class="line"></line>
        <line x1="4" y1="12" x2="20" y2="12" class="line"></line>
        <line x1="4" y1="17" x2="20" y2="17" class="line"></line>
        <line x1="18" y1="6" x2="6" y2="18" class="close"></line>
        <line x1="6" y1="6" x2="18" y2="18" class="close"></line>
      </svg>
    </button>

    <div id="mobile-panel" class="mobile-panel hidden">
      <nav aria-label="Mobile navigation">
        <ul class="mobile-nav-list">
          <li class="mobile-group">
            <details>
              <summary class:list={["mobile-link", { active: activeNav === "courses" }]}>
                Courses
                <svg xmlns="http://www.w3.org/2000/svg" class="chevron">
                  <path d="m7 10 5 5 5-5z"></path>
                </svg>
              </summary>
              <ul class="mobile-submenu">
                {courseLinks.map(link => (
                  <li>
                    <a href={link.href} class="dropdown-link">
                      <span class="dropdown-name">{link.name}</span>
                      <span class="dropdown-desc">{link.description}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          </li>

          <li class="mobile-group">
            <details>
              <summary class:list={["mobile-link", { active: activeNav === "consultancy" }]}>
                Consult
                <svg xmlns="http://www.w3.org/2000/svg" class="chevron">
                  <path d="m7 10 5 5 5-5z"></path>
                </svg>
              </summary>
              <ul class="mobile-submenu">
                {consultLinks.map(link => (
                  <li>
                    <a
                      href={link.href}
                      class="dropdown-link"
                      target={link.external ? "_blank" : undefined}
                      rel={link.external ? "noopener noreferrer" : undefined}
                    >
                      <span class="dropdown-name">{link.name}</span>
                      <span class="dropdown-desc">{link.description}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </details>
          </li>

          <li>
            <a href="/research" class:list={["mobile-link", { active: activeNav === "research" }]}>
              Research
            </a>
          </li>
          <li>
            <a href="/pricing" class:list={["mobile-link", { active: activeNav === "pricing" }]}>
              Pricing
            </a>
          </li>
          <li>
            <a href="/posts" class:list={["mobile-link", { active: activeNav === "posts" }]}>
              Insights
            </a>
          </li>
          <li>
            <a href="/about" class:list={["mobile-link", { active: activeNav === "about" }]}>
              About
            </a>
          </li>
        </ul>
      </nav>

      <div class="mobile-actions">
        <LinkButton
          href={CONSULT_BOOKING_LINKS.quick15}
          className="mobile-cta"
          target="_blank"
          rel="noopener noreferrer"
        >
          Book 15-Min Call
        </LinkButton>
        <LinkButton href="/search" className="mobile-secondary">
          Search Insights
        </LinkButton>
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: clamp(0.55rem, 1.5vw, 0.95rem);
    z-index: 60;
    padding-inline: clamp(0.7rem, 2.5vw, 1.7rem);
    transition: top 220ms ease;
  }
  .skip-link {
    @apply absolute -top-full left-8 z-50 rounded-full bg-skin-accent px-4 py-2 text-sm font-semibold text-skin-inverted transition-all focus:top-2;
  }

  .nav-shell {
    max-width: 1360px;
    margin: 0 auto;
    border: 1px solid rgb(var(--color-border));
    border-radius: 20px;
    background: rgba(var(--color-card), 0.9);
    backdrop-filter: blur(14px);
    box-shadow:
      0 14px 32px rgba(6, 23, 39, 0.12),
      0 4px 10px rgba(6, 23, 39, 0.08);
    width: 100%;
    padding: 0.78rem 1rem;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 0.7rem 0.9rem;
    transition:
      padding 220ms ease,
      box-shadow 220ms ease,
      background-color 220ms ease;
  }

  .logo {
    min-width: 0;
    display: block;
    max-width: 100%;
  }
  .logo > span {
    display: block;
    min-width: 0;
    max-width: 100%;
  }
  .brand-kicker {
    display: block;
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    opacity: 0.72;
    white-space: nowrap;
    text-overflow: ellipsis;
    max-height: 1rem;
    overflow: hidden;
    transition:
      max-height 220ms ease,
      opacity 220ms ease,
      transform 220ms ease;
  }
  .brand-title {
    display: block;
    font-size: clamp(1.2rem, 1.4vw + 0.7rem, 1.7rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: font-size 220ms ease;
  }
  .logo img,
  .logo svg {
    @apply inline-block;
  }

  .desktop-nav,
  .desktop-actions {
    display: none;
  }

  .mobile-toggle {
    @apply rounded-xl border border-skin-line bg-skin-fill p-2;
    justify-self: end;
  }
  .mobile-toggle svg {
    @apply h-6 w-6 fill-none stroke-current;
  }

  .mobile-panel {
    grid-column: 1 / -1;
    border-top: 1px solid rgba(var(--color-border), 0.75);
    padding-top: 0.75rem;
  }
  .mobile-nav-list {
    display: grid;
    gap: 0.4rem;
  }
  .mobile-link {
    @apply inline-flex w-full items-center justify-between rounded-full px-3 py-2 text-sm font-semibold;
  }
  .mobile-link.active {
    @apply bg-skin-fill text-skin-accent;
  }
  .mobile-group summary {
    list-style: none;
    cursor: pointer;
  }
  .mobile-group summary::-webkit-details-marker {
    display: none;
  }
  .mobile-submenu {
    display: none;
    margin-top: 0.35rem;
    gap: 0.35rem;
    border: 1px solid rgb(var(--color-border));
    border-radius: 12px;
    background: rgba(var(--color-fill), 0.6);
    padding: 0.35rem;
  }
  .mobile-group details[open] > .mobile-submenu {
    display: grid;
  }

  .dropdown-link {
    display: block;
    border-radius: 10px;
    padding: 0.45rem 0.55rem;
    transition: background-color 150ms ease;
  }
  .dropdown-link:hover {
    background: rgba(var(--color-fill), 0.7);
  }
  .dropdown-name {
    display: block;
    font-size: 0.88rem;
    font-weight: 600;
  }
  .dropdown-desc {
    display: block;
    margin-top: 0.1rem;
    font-size: 0.74rem;
    opacity: 0.72;
  }
  .chevron {
    @apply h-4 w-4 fill-skin-base transition-transform;
  }
  details[open] .chevron {
    transform: rotate(180deg);
  }

  .mobile-actions {
    display: grid;
    gap: 0.45rem;
    margin-top: 0.7rem;
  }
  .mobile-cta {
    @apply inline-flex w-full justify-center rounded-full border border-skin-accent bg-skin-accent px-4 py-2 text-sm font-semibold text-skin-inverted transition hover:bg-skin-fill hover:text-skin-accent;
  }
  .mobile-secondary {
    @apply inline-flex w-full justify-center rounded-full border border-skin-line bg-skin-fill px-4 py-2 text-sm font-semibold transition hover:border-skin-accent hover:text-skin-accent;
  }

  .menu-icon line {
    @apply transition-opacity duration-100 ease-in-out;
  }
  .menu-icon .close {
    opacity: 0;
  }
  .menu-icon.is-active .line {
    @apply opacity-0;
  }
  .menu-icon.is-active .close {
    @apply opacity-100;
  }

  @media (min-width: 960px) {
    .nav-shell {
      grid-template-columns: minmax(240px, 1.2fr) auto minmax(250px, 1fr);
      min-height: 4.5rem;
      padding: 0.68rem 1.08rem;
      gap: 0.75rem 1.15rem;
    }

    .desktop-nav {
      display: block;
      grid-column: 2;
      justify-self: center;
    }
    .desktop-nav-list {
      display: flex;
      align-items: center;
      gap: 0.3rem;
    }
    .desktop-link {
      @apply inline-flex items-center gap-1 rounded-full px-3 py-2 text-sm font-semibold;
    }
    .desktop-link:hover {
      @apply text-skin-accent;
    }
    .desktop-link.active {
      @apply bg-skin-fill text-skin-accent shadow-sm;
    }

    .desktop-dropdown {
      position: relative;
    }
    .desktop-dropdown details {
      position: relative;
    }
    .desktop-dropdown summary {
      list-style: none;
      cursor: pointer;
    }
    .desktop-dropdown summary::-webkit-details-marker {
      display: none;
    }
    .desktop-dropdown .dropdown-menu {
      display: none;
      position: absolute;
      top: calc(100% + 0.6rem);
      left: 50%;
      transform: translateX(-50%);
      min-width: 19rem;
      border: 1px solid rgb(var(--color-border));
      border-radius: 14px;
      background: rgba(var(--color-card), 0.97);
      box-shadow:
        0 20px 38px rgba(5, 20, 34, 0.16),
        0 6px 16px rgba(5, 20, 34, 0.1);
      padding: 0.5rem;
      z-index: 80;
      gap: 0.3rem;
    }
    .desktop-dropdown details[open] .dropdown-menu,
    .desktop-dropdown:hover .dropdown-menu,
    .desktop-dropdown:focus-within .dropdown-menu {
      display: grid;
    }

    .desktop-actions {
      display: flex;
      align-items: center;
      justify-self: end;
      gap: 0.55rem;
      grid-column: 3;
    }
    .icon-btn {
      @apply inline-flex rounded-full border border-skin-line bg-skin-fill p-2 hover:border-skin-accent;
    }
    .icon-btn.active {
      @apply border-skin-accent;
    }
    .search-icon,
    .theme-icon {
      @apply scale-110;
    }
    .cta-btn {
      @apply inline-flex rounded-full border border-skin-accent bg-skin-accent px-4 py-2 text-sm font-semibold text-skin-inverted transition hover:bg-skin-fill hover:text-skin-accent;
    }

    .mobile-toggle,
    .mobile-panel {
      display: none !important;
    }
  }

  @media (min-width: 960px) and (max-width: 1160px) {
    .brand-kicker {
      max-height: 0;
      opacity: 0;
      transform: translateY(-3px);
    }
    .brand-title {
      font-size: 1.12rem;
    }
    .desktop-link {
      padding-inline: 0.58rem;
    }
    .cta-btn {
      padding-inline: 0.92rem;
    }
  }

  .site-header.is-scrolled {
    top: 0.28rem;
  }
  .site-header.is-scrolled .nav-shell {
    padding-top: 0.48rem;
    padding-bottom: 0.48rem;
    box-shadow:
      0 12px 26px rgba(5, 20, 34, 0.16),
      0 4px 10px rgba(5, 20, 34, 0.09);
    background: rgba(var(--color-card), 0.96);
  }
  .site-header.is-scrolled .brand-kicker {
    max-height: 0;
    opacity: 0;
    transform: translateY(-4px);
  }
</style>

<script>
  const setupNavbar = () => {
    const headerRoot = document.querySelector(".site-header");
    if (!(headerRoot instanceof HTMLElement)) return;
    if (headerRoot.dataset.initialized === "true") return;

    const navShell = headerRoot.querySelector(".nav-shell");
    const mobileToggle = headerRoot.querySelector(".mobile-toggle");
    const mobilePanel = headerRoot.querySelector("#mobile-panel");
    const menuIcon = headerRoot.querySelector(".menu-icon");
    const detailsList = Array.from(headerRoot.querySelectorAll("details"));

    if (
      !(navShell instanceof HTMLElement) ||
      !(mobileToggle instanceof HTMLButtonElement) ||
      !(mobilePanel instanceof HTMLElement) ||
      !(menuIcon instanceof SVGElement)
    ) {
      return;
    }

    headerRoot.dataset.initialized = "true";

    const closeAllDetails = () => {
      detailsList.forEach(item => {
        if (item instanceof HTMLDetailsElement) {
          item.open = false;
        }
      });
    };

    const closeMobilePanel = () => {
      mobilePanel.classList.add("hidden");
      mobileToggle.setAttribute("aria-expanded", "false");
      mobileToggle.setAttribute("aria-label", "Open navigation menu");
      menuIcon.classList.remove("is-active");
    };

    const toggleMobilePanel = () => {
      const isExpanded = mobileToggle.getAttribute("aria-expanded") === "true";
      mobilePanel.classList.toggle("hidden", isExpanded);
      mobileToggle.setAttribute("aria-expanded", String(!isExpanded));
      mobileToggle.setAttribute(
        "aria-label",
        isExpanded ? "Open navigation menu" : "Close navigation menu"
      );
      menuIcon.classList.toggle("is-active", !isExpanded);
    };

    const updateHeaderState = () => {
      if (window.scrollY > 20) {
        headerRoot.classList.add("is-scrolled");
      } else {
        headerRoot.classList.remove("is-scrolled");
      }
    };

    updateHeaderState();
    mobileToggle.addEventListener("click", toggleMobilePanel);
    window.addEventListener("scroll", updateHeaderState, { passive: true });

    headerRoot.querySelectorAll("a").forEach(link => {
      link.addEventListener("click", () => {
        closeMobilePanel();
        closeAllDetails();
      });
    });

    document.addEventListener("click", event => {
      const targetNode = event.target;
      if (!(targetNode instanceof Node)) return;

      if (!navShell.contains(targetNode)) {
        closeMobilePanel();
        closeAllDetails();
      }
    });

    document.addEventListener("keydown", event => {
      if (event.key === "Escape") {
        closeMobilePanel();
        closeAllDetails();
      }
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth >= 960) {
        closeMobilePanel();
      }
    });
  };

  document.addEventListener("DOMContentLoaded", setupNavbar);
  document.addEventListener("astro:after-swap", setupNavbar);
</script>
