---
import LinkButton from "./LinkButton.astro";

export interface Props {
  currentPage: number;
  totalPages: number;
  prevUrl: string;
  nextUrl: string;
}

const { currentPage, totalPages, prevUrl, nextUrl } = Astro.props;

const isPrevDisabled = currentPage <= 1;
const isNextDisabled = currentPage >= totalPages;
---

{
  totalPages > 1 && (
    <nav class="pagination-wrapper" aria-label="Pagination">
      <LinkButton
        disabled={isPrevDisabled}
        href={prevUrl}
        class:list={["mr-4", "select-none", { "disabled": isPrevDisabled }]}
        ariaLabel="Previous page"
        title="Go to previous page"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class:list={[{ "disabled-svg": isPrevDisabled }]}>
          <path d="M12.707 17.293 8.414 13H18v-2H8.414l4.293-4.293-1.414-1.414L4.586 12l6.707 6.707z" />
        </svg>
        Previous
      </LinkButton>
      <span class="page-indicator">
        {currentPage} / {totalPages}
      </span>
      <LinkButton
        disabled={isNextDisabled}
        href={nextUrl}
        class:list={["ml-4", "select-none", { "disabled": isNextDisabled }]}
        ariaLabel="Next page"
        title="Go to next page"
      >
        Next
        <svg xmlns="http://www.w3.org/2000/svg" class:list={[{ "disabled-svg": isNextDisabled }]}>
          <path d="m11.293 17.293 1.414 1.414L19.414 12l-6.707-6.707-1.414 1.414L15.586 11H6v2h9.586z" />
        </svg>
      </LinkButton>
    </nav>
  )
}

<style>
  .pagination-wrapper {
    @apply mb-10 mt-2 flex items-center justify-center gap-3;
  }
  .pagination-wrapper a {
    @apply rounded-full border border-skin-line bg-skin-card px-4 py-2 text-sm font-semibold hover:border-skin-accent;
  }
  .page-indicator {
    @apply rounded-full border border-skin-line bg-skin-fill px-4 py-2 text-sm font-semibold;
  }
  .disabled {
    @apply pointer-events-none select-none opacity-45 hover:text-skin-base group-hover:fill-skin-base;
  }
  .disabled-svg {
    @apply group-hover:!fill-skin-base;
  }
</style>
