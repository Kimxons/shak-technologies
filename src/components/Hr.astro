---
export interface Props {
  noPadding?: boolean;
  ariaHidden?: boolean;
}

const { noPadding = false, ariaHidden = true } = Astro.props;
---

<div class:list={["max-w-7xl", "mx-auto", { "px-0": noPadding, "px-4 sm:px-6": !noPadding }]}>
  <hr class="border-skin-line" aria-hidden={ariaHidden} />
</div>
